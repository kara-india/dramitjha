// KrishnaHealth ERP — Prisma Schema
// Dr. Amit Jha Sports Injury Clinic, Varanasi
// Generated by Chief Architect — 10-Agent Synthesis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  RECEPTIONIST
  DOCTOR
  PHYSIOTHERAPIST
  PHARMACIST
  ACCOUNTANT
}

enum Department {
  ORTHOPEDIC
  PEDIATRICS
  PHYSIOTHERAPY
  GENERAL
  OT // Operation Theatre
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
  UNKNOWN
}

enum AppointmentStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_TRIAGE
  READY_FOR_DOCTOR
  IN_CONSULTATION
  PENDING_DIAGNOSTICS
  REVIEW_READY
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  PROCEDURE
  PHYSIOTHERAPY
  VACCINATION
  SURGERY_OT
  WALK_IN
}

enum OTStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ConsultationStatus {
  IN_PROGRESS
  COMPLETED
  SIGNED_OFF
}

enum PrescriptionStatus {
  ACTIVE
  DISPENSED
  CANCELLED
  EXPIRED
}

enum InventoryItemType {
  MEDICINE
  CONSUMABLE
  IMPLANT
  CONSIGNMENT_IMPLANT // Separate tracking, not clinic-owned until used
  VACCINE
  EQUIPMENT
  SURGICAL_SUPPLY
}

enum MovementType {
  PURCHASE_RECEIPT
  PATIENT_ISSUE
  DEPARTMENT_TRANSFER
  PATIENT_RETURN
  VENDOR_RETURN
  ADJUSTMENT
  WRITE_OFF
  CONSIGNMENT_USED   // For consignment implants when used in surgery
  CONSIGNMENT_RETURN // Unused consignment returned to supplier
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMode {
  CASH
  UPI
  CARD_CREDIT
  CARD_DEBIT
  INSURANCE_TPA
  SPLIT
  ONLINE_TRANSFER
}

enum TPAStatus {
  VERIFICATION_PENDING
  PRE_AUTH_SUBMITTED
  PRE_AUTH_APPROVED
  PRE_AUTH_REJECTED
  CLAIM_SUBMITTED
  CLAIM_SETTLED
  CLAIM_REJECTED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryType {
  INVOICE_RAISED
  PAYMENT_RECEIVED
  INVENTORY_ISSUED
  REFUND_PROCESSED
  CREDIT_NOTE
  MANUAL_ADJUSTMENT
  TDS_ADJUSTMENT
  DAILY_SETTLEMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  LOGIN
  LOGOUT
  EXPORT
}

enum AlertType {
  LOW_STOCK
  NEAR_EXPIRY
  PAYMENT_OVERDUE
  APPOINTMENT_REMINDER
  OT_REMINDER
  SYSTEM
}

enum Allergyseverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

// ============================================================
// MULTI-TENANCY — TENANT (Clinic / Branch)
// ============================================================

model Tenant {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  address         String?
  city            String?  @default("Varanasi")
  state           String?  @default("Uttar Pradesh")
  pincode         String?
  phone           String?
  email           String?
  website         String?
  gstNumber       String?
  registrationNo  String?
  logo            String?  // Supabase Storage URL
  timezone        String   @default("Asia/Kolkata")
  currency        String   @default("INR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  patients        Patient[]
  appointments    Appointment[]
  otSchedules     OTSchedule[]
  consultations   Consultation[]
  inventoryItems  InventoryItem[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
  invoices        Invoice[]
  payments        Payment[]
  accounts        Account[]
  journalEntries  JournalEntry[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  gstRates        GSTRate[]

  @@map("tenants")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id              String     @id @default(cuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  supabaseUserId  String     @unique // Supabase auth.users.id
  email           String
  firstName       String
  lastName        String
  phone           String?
  role            UserRole
  department      Department?
  qualification   String?    // e.g. MBBS, MS(Ortho), DNB, FNB
  registrationNo  String?    // Medical Council registration
  signature       String?    // Supabase Storage URL
  avatar          String?    // Supabase Storage URL
  isActive        Boolean    @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  doctorAppointments    Appointment[]   @relation("DoctorAppointments")
  consultations         Consultation[]  @relation("DoctorConsultations")
  physioSessions        PhysioSession[] @relation("PhysioSessions")
  otSchedulesSurgeon    OTSchedule[]    @relation("Surgeon")
  otSchedulesAnesthesia OTSchedule[]    @relation("Anesthesiologist")
  stockMovements        StockMovement[]
  auditLogs             AuditLog[]
  createdInvoices       Invoice[]
  receivedPayments      Payment[]

  @@unique([tenantId, email])
  @@unique([tenantId, supabaseUserId])
  @@index([tenantId])
  @@index([role])
  @@map("users")
}

// ============================================================
// PATIENT REGISTRATION
// ============================================================

model Patient {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  mrn             String      // Medical Record Number: KH-YYYY-XXXXXX
  
  // Demographics
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      BloodGroup  @default(UNKNOWN)
  
  // Contact
  phone           String
  altPhone        String?
  email           String?
  
  // Address
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  
  // Medical
  abhaId          String?     // Ayushman Bharat Health Account (for later)
  
  // Insurance
  insuranceName   String?
  policyNumber    String?
  tpaName         String?
  
  // Meta
  referredBy      String?
  occupation      String?
  photo           String?     // Supabase Storage URL
  notes           String?     // General notes by receptionist
  
  isActive        Boolean     @default(true)
  registeredAt    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  emergencyContacts EmergencyContact[]
  allergies          Allergy[]
  appointments       Appointment[]
  consultations      Consultation[]
  otSchedules        OTSchedule[]
  invoices           Invoice[]
  tpaClaims          TPAClaim[]
  vaccinations       Vaccination[]
  growthRecords      GrowthRecord[]

  @@unique([tenantId, mrn])
  @@index([tenantId])
  @@index([phone])
  @@index([tenantId, firstName, lastName])
  @@map("patients")
}

model EmergencyContact {
  id           String  @id @default(cuid())
  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id])
  name         String
  relationship String
  phone        String
  altPhone     String?
  isPrimary    Boolean @default(false)

  @@index([patientId])
  @@map("emergency_contacts")
}

model Allergy {
  id           String          @id @default(cuid())
  patientId    String
  patient      Patient         @relation(fields: [patientId], references: [id])
  allergen     String          // e.g. "Penicillin", "Aspirin", "Latex"
  severity     Allergyseverity
  reaction     String?         // Clinical description
  onsetDate    DateTime?
  isActive     Boolean         @default(true)
  notes        String?
  createdAt    DateTime        @default(now())

  @@index([patientId])
  @@map("allergies")
}

// ============================================================
// APPOINTMENT SCHEDULING
// ============================================================

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  
  appointmentNo   String            // Auto-generated: APT-YYYY-XXXXX
  type            AppointmentType   @default(CONSULTATION)
  department      Department
  status          AppointmentStatus @default(SCHEDULED)
  
  scheduledDate   DateTime
  scheduledTime   String            // "09:00" in HH:mm format (IST)
  durationMinutes Int               @default(30)
  
  // Workflow timestamps
  checkedInAt     DateTime?
  triageStartAt   DateTime?
  consultStartAt  DateTime?
  completedAt     DateTime?
  
  chiefComplaint  String?
  priority        String            @default("ROUTINE") // ROUTINE, URGENT, EMERGENCY
  isWalkIn        Boolean           @default(false)
  notes           String?
  
  // Reminders
  reminderSent    Boolean           @default(false)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  consultation    Consultation?
  statusHistory   AppointmentStatusHistory[]

  @@unique([tenantId, doctorId, scheduledDate, scheduledTime])
  @@index([tenantId, scheduledDate])
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id            String            @id @default(cuid())
  appointmentId String
  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedAt     DateTime          @default(now())
  changedBy     String?           // User ID
  notes         String?

  @@index([appointmentId])
  @@map("appointment_status_history")
}

// ============================================================
// OT SURGERY SCHEDULING
// ============================================================

model OTSchedule {
  id                  String     @id @default(cuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id])
  patientId           String
  patient             Patient    @relation(fields: [patientId], references: [id])
  surgeonId           String
  surgeon             User       @relation("Surgeon", fields: [surgeonId], references: [id])
  anesthesiologistId  String?
  anesthesiologist    User?      @relation("Anesthesiologist", fields: [anesthesiologistId], references: [id])
  
  otNumber            String     // OT-YYYY-XXXXX
  otRoom              String     @default("OT-1")
  surgeryType         String     // e.g. "ACL Reconstruction", "Arthroscopy", "Meniscus Repair"
  surgeryCategory     String?    // e.g. "Elective", "Emergency"
  procedureCode       String?    // ICD-10-PCS code
  
  scheduledDate       DateTime
  startTime           String     // HH:mm
  estimatedDurationMins Int      @default(120)
  
  status              OTStatus   @default(SCHEDULED)
  
  // Pre-op
  pacDone             Boolean    @default(false) // Pre-Anesthesia Check
  pacDate             DateTime?
  consentSigned       Boolean    @default(false)
  consentSignedAt     DateTime?
  bloodArranged       Boolean    @default(false)
  npoBefore           DateTime?  // Nil Per Os (nothing by mouth) from time
  
  // Intra-op
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  implantUsed         Boolean    @default(false)
  implantDetails      String?    // JSONB stored as string for now
  anesthesiaType      String?    // General, Spinal, Regional, Local
  anesthesiaNotes     String?
  
  // Post-op
  postOpNotes         String?
  recoveryRoomUntil   DateTime?
  wardAdmitted        Boolean    @default(false)
  
  diagnosis           String?
  notes               String?
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  @@index([tenantId, scheduledDate])
  @@index([patientId])
  @@index([surgeonId])
  @@map("ot_schedules")
}

// ============================================================
// CONSULTATION & SOAP NOTES
// ============================================================

model Consultation {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  appointmentId   String             @unique
  appointment     Appointment        @relation(fields: [appointmentId], references: [id])
  patientId       String
  patient         Patient            @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          User               @relation("DoctorConsultations", fields: [doctorId], references: [id])
  
  department      Department
  status          ConsultationStatus @default(IN_PROGRESS)
  
  startTime       DateTime?
  endTime         DateTime?
  
  // SOAP Notes
  subjective      String?            // Chief complaint, history
  objective       String?            // Examination findings, vitals
  assessment      String?            // Diagnosis, ICD-10 codes
  plan            String?            // Treatment plan, referrals
  
  // Vitals (stored as JSONB)
  vitals          Json?
  // {
  //   bp_systolic: number, bp_diastolic: number,
  //   heart_rate: number, temperature: number,
  //   spo2: number, weight: number, height: number,
  //   bmi: number, vas_pain_score: number (0-10),
  //   respiratory_rate: number, random_blood_sugar: number
  // }
  
  // Diagnosis
  primaryDiagnosis    String?        // ICD-10 code + description
  secondaryDiagnoses  Json?          // Array of {code, description}
  
  // Department-specific data
  orthopedicData  OrthopedicRecord?
  pediatricData   PediatricRecord?
  physioData      PhysioRecord?
  
  // References
  prescriptions   Prescription[]
  files           MedicalFile[]
  procedures      Procedure[]
  
  followUpDate    DateTime?
  followUpNotes   String?
  
  isSignedOff     Boolean            @default(false)
  signedOffAt     DateTime?
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([patientId])
  @@index([doctorId])
  @@index([tenantId, createdAt])
  @@map("consultations")
}

// ============================================================
// DEPARTMENT-SPECIFIC EMR RECORDS
// ============================================================

model OrthopedicRecord {
  id                  String       @id @default(cuid())
  consultationId      String       @unique
  consultation        Consultation @relation(fields: [consultationId], references: [id])
  
  // Mechanism of Injury
  moiDescription      String?
  moiDate             DateTime?
  sportActivity       String?      // Sport or activity involved
  
  // Clinical Assessment
  affectedSide        String?      // LEFT, RIGHT, BILATERAL
  affectedJoint       String?      // KNEE, SHOULDER, ANKLE, HIP, ELBOW, WRIST
  vasPainScore        Int?         // 0-10
  swelling            Boolean      @default(false)
  deformity           Boolean      @default(false)
  tenderness          String?
  
  // Special Tests (stored as JSONB)
  specialTests        Json?
  // {
  //   lachmans: "POSITIVE" | "NEGATIVE" | "NOT_DONE",
  //   anterior_drawer: "POSITIVE" | "NEGATIVE" | "NOT_DONE",
  //   posterior_drawer: string, mcmurray: string,
  //   valgus_stress: string, varus_stress: string,
  //   apprehension: string, sulcus_sign: string
  // }
  
  // Range of Motion
  romFindings         Json?
  // { flexion: number, extension: number, abduction: number, etc. }
  
  // Imaging
  xrayFindings        String?
  mriFindings         String?
  
  // Implant Registry
  implantUsed         Boolean      @default(false)
  implantDetails      Json?
  // [{
  //   inventoryItemId: string, manufacturer: string, implantName: string,
  //   catalogueNo: string, batchNo: string, serialNo: string,
  //   expiryDate: date, size: string
  // }]
  
  // Management
  surgicalIntervention Boolean     @default(false)
  surgeryType         String?
  otScheduleId        String?      // Link to OT if surgery planned
  
  castApplied         Boolean      @default(false)
  braceType           String?
  physiotherapyReferred Boolean   @default(false)
  
  notes               String?
  
  @@map("orthopedic_records")
}

model PediatricRecord {
  id                  String       @id @default(cuid())
  consultationId      String       @unique
  consultation        Consultation @relation(fields: [consultationId], references: [id])
  
  // Anthropometry at this visit
  weightKg            Float?
  heightCm            Float?
  headCircumferenceCm Float?
  bmi                 Float?
  weightPercentile    Float?
  heightPercentile    Float?
  bmiPercentile       Float?
  
  // History
  feedingHistory      String?      // Breastfed, formula, mixed, solids
  sleepPattern        String?
  bowelBladder        String?
  
  // Development Milestones (assessed this visit)
  milestonesAchieved  Json?
  // { gross_motor: [], fine_motor: [], speech: [], social: [], cognitive: [] }
  developmentalDelay  Boolean      @default(false)
  
  // Vaccination this visit
  vaccinesGiven       Json?
  // [{ vaccineId: string, batchNo: string, dose: string, site: string }]
  
  // M-CHAT screening
  mchatScore          Int?
  mchatResult         String?      // PASS, FAIL, REFER
  
  // Weight-based Rx
  weightAtPrescription Float?
  
  notes               String?
  
  @@map("pediatric_records")
}

model PhysioRecord {
  id                  String       @id @default(cuid())
  consultationId      String       @unique
  consultation        Consultation @relation(fields: [consultationId], references: [id])
  
  // Initial Assessment
  referralSource      String?      // "Orthopedic", "Self", "External"
  referringDoctor     String?
  diagnosisReferred   String?
  
  // Functional Assessment
  bodyChartData       Json?        // SVG pain point coordinates + descriptors
  // [{ x: number, y: number, painType: "SHARP"|"DULL"|"BURNING", intensity: number }]
  
  // ROM (Goniometry)
  romFindings         Json?
  
  // Strength Testing
  strengthFindings    Json?        // MMT grades per muscle group
  
  // Treatment Plan
  shortTermGoals      String?
  longTermGoals       String?
  treatmentProtocol   String?      // e.g. "ACL Rehab Phase 1 Protocol"
  estimatedSessions   Int?
  sessionFrequency    String?      // "3x per week"
  
  // Outcome Scores
  koosScore           Json?        // KOOS subscores
  lysholmScore        Int?
  dashScore           Float?
  vasScore            Int?         // 0-10
  
  // HEP
  hepPrescribed       Boolean      @default(false)
  hepDetails          Json?
  // [{ exercise: string, sets: number, reps: number, hold: number, frequency: string, notes: string }]
  
  notes               String?
  
  physioSessions      PhysioSession[]
  
  @@map("physio_records")
}

model PhysioSession {
  id              String        @id @default(cuid())
  physioRecordId  String
  physioRecord    PhysioRecord  @relation(fields: [physioRecordId], references: [id])
  physioId        String
  physio          User          @relation("PhysioSessions", fields: [physioId], references: [id])
  
  sessionNo       Int           // 1, 2, 3... (auto-increment per patient)
  scheduledDate   DateTime
  scheduledTime   String        // HH:mm (must be within physio slots)
  durationMinutes Int           @default(30)
  
  attendanceStatus String       @default("SCHEDULED") // SCHEDULED, PRESENT, ABSENT, CANCELLED
  
  // Modalities used this session
  modalities      Json?
  // [{ type: "TENS"|"IFT"|"ULTRASOUND"|"HOTPACK"|"CRYOTHERAPY",
  //    parameters: { frequency?: number, intensity?: number, duration_mins: number } }]
  
  // Exercises done this session
  exercises       Json?
  // [{ name: string, sets: number, reps: number, hold: number, completed: boolean }]
  
  // Measurements this session
  romMeasurements Json?
  vasPre          Int?          // VAS score before session
  vasPost         Int?          // VAS score after session
  
  // Session notes
  sessionNotes    String?
  homeCompliance  String?       // "GOOD", "FAIR", "POOR" — HEP compliance
  progressNotes   String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([physioRecordId])
  @@index([physioId])
  @@index([scheduledDate])
  @@map("physio_sessions")
}

// ============================================================
// PRESCRIPTIONS
// ============================================================

model Prescription {
  id              String             @id @default(cuid())
  consultationId  String
  consultation    Consultation       @relation(fields: [consultationId], references: [id])
  patientId       String
  
  status          PrescriptionStatus @default(ACTIVE)
  prescribedAt    DateTime           @default(now())
  validUntil      DateTime?
  
  items           PrescriptionItem[]
  
  notes           String?
  dispensedAt     DateTime?
  dispensedBy     String?            // Pharmacist User ID

  @@index([consultationId])
  @@index([patientId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              String        @id @default(cuid())
  prescriptionId  String
  prescription    Prescription  @relation(fields: [prescriptionId], references: [id])
  inventoryItemId String?       // Links to inventory
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  
  medicineName    String
  genericName     String?
  dosage          String       // e.g. "500mg", "5mg/5ml"
  frequency       String       // e.g. "TDS", "BD", "OD", "SOS"
  duration        String       // e.g. "5 days", "1 week"
  route           String       @default("ORAL") // ORAL, IV, IM, TOPICAL, INHALED
  instructions    String?      // "After food", "Before sleep"
  quantity        Int          @default(1)
  unit            String       @default("tablets")
  
  // Pediatric dosing
  weightKgAtPrescription Float?
  dosePerKg       Float?
  calculatedDose  Float?
  maxDosePerDay   Float?

  @@index([prescriptionId])

  @@map("prescription_items")
}

// ============================================================
// MEDICAL FILES (X-Ray, MRI, Reports, Consent)
// ============================================================

model MedicalFile {
  id              String       @id @default(cuid())
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id])
  patientId       String
  
  fileType        String       // XRAY, MRI, LAB_REPORT, CONSENT, PHOTO, OTHER
  fileName        String
  fileUrl         String       // Supabase Storage signed URL path
  fileSizeBytes   Int?
  mimeType        String?
  
  description     String?
  uploadedBy      String       // User ID
  uploadedAt      DateTime     @default(now())

  @@index([consultationId])
  @@index([patientId])
  @@map("medical_files")
}

// ============================================================
// PROCEDURES
// ============================================================

model Procedure {
  id              String       @id @default(cuid())
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id])
  
  procedureName   String
  procedureCode   String?      // ICD-10-PCS or custom
  performedBy     String?      // Doctor/Physio name
  performedAt     DateTime     @default(now())
  
  // Billing linkage
  chargeAmount    Decimal      @default(0) @db.Decimal(10, 2)
  notes           String?

  @@index([consultationId])
  @@map("procedures")
}

// ============================================================
// PEDIATRIC-SPECIFIC: VACCINATIONS & GROWTH
// ============================================================

model Vaccination {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  vaccineName     String   // e.g. "BCG", "OPV", "DTP", "MMR", "Varicella"
  doseNumber      String   // "1st", "2nd", "Booster"
  ageAtDose       String?  // "Birth", "6 weeks", "10 weeks"
  scheduledDate   DateTime
  givenDate       DateTime?
  
  inventoryItemId String?  // Links to vaccine in inventory
  batchNo         String?
  expiryDate      DateTime?
  adminSite       String?  // "Right Thigh", "Left Arm"
  administeredBy  String?  // Nurse name
  
  coldChainOk     Boolean  @default(true)
  adverseReaction String?
  nextDoseDate    DateTime?
  
  notes           String?

  @@index([patientId])
  @@map("vaccinations")
}

model GrowthRecord {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  recordDate      DateTime
  ageMonths       Int      // Age in months at recording
  weightKg        Float?
  heightCm        Float?
  headCircumCm    Float?
  bmi             Float?
  
  weightPercentile Float?
  heightPercentile Float?
  
  recordedBy      String?

  @@index([patientId, recordDate])
  @@map("growth_records")
}

// ============================================================
// INVENTORY & PHARMACY
// ============================================================

model Supplier {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  
  name            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  gstNumber       String?
  dlNumber        String?         // Drug License Number
  
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  inventoryItems  InventoryItem[]
  purchaseOrders  PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

model InventoryItem {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  supplierId      String?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  
  itemCode        String            // Internal SKU
  name            String
  genericName     String?
  category        String?           // "Antibiotic", "NSAID", "Implant", "Consumable"
  itemType        InventoryItemType @default(MEDICINE)
  
  // Units
  unit            String            @default("tablets") // tablets, ml, units, pieces
  packSize        Int               @default(1)         // tablets per strip/bottle
  
  // Pricing
  mrp             Decimal           @db.Decimal(10, 2)
  costPrice       Decimal?          @db.Decimal(10, 2)
  sellingPrice    Decimal           @db.Decimal(10, 2)
  
  // GST
  hsnCode         String?
  gstPercent      Decimal           @default(0) @db.Decimal(5, 2)
  
  // Stock
  totalQuantity   Int               @default(0)
  reservedQty     Int               @default(0)    // Blocked for pending bills
  reorderLevel    Int               @default(10)
  reorderQty      Int               @default(50)
  
  // Flags
  requiresPrescription Boolean      @default(false)
  isNarcotic      Boolean           @default(false)
  requiresColdChain Boolean         @default(false)
  isConsignment   Boolean           @default(false)  // True for CONSIGNMENT_IMPLANT
  isActive        Boolean           @default(true)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  batches         InventoryBatch[]
  stockMovements  StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  invoiceLineItems InvoiceLineItem[]
  prescriptionItems PrescriptionItem[]

  @@unique([tenantId, itemCode])
  @@index([tenantId])
  @@index([itemType])
  @@index([totalQuantity]) // For low-stock queries
  @@map("inventory_items")
}

model InventoryBatch {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  batchNumber     String
  manufacturingDate DateTime?
  expiryDate      DateTime?
  
  receivedQty     Int
  availableQty    Int           // Current available
  reservedQty     Int           @default(0)
  
  costPerUnit     Decimal       @db.Decimal(10, 2)
  mrpPerUnit      Decimal       @db.Decimal(10, 2)
  
  supplierId      String?
  purchaseOrderId String?
  
  isQuarantined   Boolean       @default(false)
  quarantineReason String?
  
  receivedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  stockMovements  StockMovement[]

  @@index([inventoryItemId])
  @@index([expiryDate])                   // FEFO queries
  @@index([inventoryItemId, expiryDate])  // Compound for FEFO
  @@map("inventory_batches")
}

model StockMovement {
  id              String        @id @default(cuid())
  tenantId        String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  batchId         String?
  batch           InventoryBatch? @relation(fields: [batchId], references: [id])
  
  movementType    MovementType
  quantity        Int           // Positive = in, Negative = out
  unitCost        Decimal?      @db.Decimal(10, 2)
  
  referenceType   String?       // "PRESCRIPTION", "INVOICE", "PURCHASE_ORDER", "ADJUSTMENT"
  referenceId     String?       // ID of the reference document
  
  fromLocation    String?       // For transfers
  toLocation      String?
  
  performedBy     String        // User ID
  performedAt     DateTime      @default(now())
  
  notes           String?

  user            User          @relation(fields: [performedBy], references: [id])

  @@index([inventoryItemId])
  @@index([tenantId, performedAt])
  @@map("stock_movements")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  
  poNumber        String              // PO-YYYY-XXXXX
  status          PurchaseOrderStatus @default(DRAFT)
  
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  
  subtotal        Decimal             @db.Decimal(12, 2)
  taxAmount       Decimal             @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal             @db.Decimal(12, 2)
  
  notes           String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  items           PurchaseOrderItem[]
  grns            GoodsReceiptNote[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  orderedQty      Int
  receivedQty     Int           @default(0)
  unitCost        Decimal       @db.Decimal(10, 2)
  totalCost       Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model GoodsReceiptNote {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  
  grnNumber       String        // GRN-YYYY-XXXXX
  receivedDate    DateTime      @default(now())
  receivedBy      String        // User ID
  
  vendorInvoiceNo String?
  vendorInvoiceDate DateTime?
  
  notes           String?
  
  createdAt       DateTime      @default(now())

  @@index([purchaseOrderId])
  @@map("goods_receipt_notes")
}

// ============================================================
// BILLING & INVOICES
// ============================================================

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  
  invoiceNumber   String        // INV-YYYY-XXXXX
  status          InvoiceStatus @default(DRAFT)
  
  // Financial
  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  taxableAmount   Decimal       @db.Decimal(12, 2)
  cgstAmount      Decimal       @default(0) @db.Decimal(12, 2)
  sgstAmount      Decimal       @default(0) @db.Decimal(12, 2)
  igstAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  balanceAmount   Decimal       @db.Decimal(12, 2)
  
  // Insurance
  insuranceCoveredAmount Decimal @default(0) @db.Decimal(12, 2)
  patientResponsibility  Decimal @default(0) @db.Decimal(12, 2)
  
  // Dates
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  confirmedAt     DateTime?
  
  // GST Place of Supply (for IGST determination)
  patientState    String?
  
  notes           String?
  printCount      Int           @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  lineItems       InvoiceLineItem[]
  payments        Payment[]
  tpaClaims       TPAClaim[]
  journalEntries  JournalEntry[]
  creditNotes     CreditNote[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, invoiceDate])
  @@index([patientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id              String         @id @default(cuid())
  invoiceId       String
  invoice         Invoice        @relation(fields: [invoiceId], references: [id])
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  
  itemType        String         // "CONSULTATION", "PROCEDURE", "MEDICINE", "CONSUMABLE", "ROOM", "OTHER"
  description     String
  hsnSacCode      String?
  
  quantity        Decimal        @default(1) @db.Decimal(10, 3)
  unitPrice       Decimal        @db.Decimal(10, 2)
  discountPercent Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal        @default(0) @db.Decimal(10, 2)
  taxableAmount   Decimal        @db.Decimal(10, 2)
  
  cgstRate        Decimal        @default(0) @db.Decimal(5, 2)
  cgstAmount      Decimal        @default(0) @db.Decimal(10, 2)
  sgstRate        Decimal        @default(0) @db.Decimal(5, 2)
  sgstAmount      Decimal        @default(0) @db.Decimal(10, 2)
  igstRate        Decimal        @default(0) @db.Decimal(5, 2)
  igstAmount      Decimal        @default(0) @db.Decimal(10, 2)
  
  totalAmount     Decimal        @db.Decimal(10, 2)
  
  // Doctor attribution for revenue share
  doctorId        String?
  
  sortOrder       Int            @default(0)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  invoiceId       String
  invoice         Invoice     @relation(fields: [invoiceId], references: [id])
  receivedById    String
  receivedBy      User        @relation(fields: [receivedById], references: [id])
  
  paymentMode     PaymentMode
  amount          Decimal     @db.Decimal(12, 2)
  
  // Reference numbers
  transactionId   String?     // UPI/Card transaction ID
  chequeNo        String?
  bankName        String?
  
  paymentDate     DateTime    @default(now())
  
  // For insurance payments
  tpaId           String?
  tdsAmount       Decimal     @default(0) @db.Decimal(10, 2)
  
  notes           String?
  isRefund        Boolean     @default(false)
  refundReason    String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([invoiceId])
  @@index([tenantId, paymentDate])
  @@map("payments")
}

model CreditNote {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  
  creditNoteNo    String   // CN-YYYY-XXXXX
  amount          Decimal  @db.Decimal(12, 2)
  cgstAmount      Decimal  @default(0) @db.Decimal(10, 2)
  sgstAmount      Decimal  @default(0) @db.Decimal(10, 2)
  reason          String
  
  issuedAt        DateTime @default(now())
  issuedBy        String   // User ID

  @@index([invoiceId])
  @@map("credit_notes")
}

// ============================================================
// INSURANCE / TPA
// ============================================================

model TPAClaim {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  invoiceId       String
  invoice         Invoice   @relation(fields: [invoiceId], references: [id])
  
  tpaName         String
  policyNumber    String
  corporateName   String?
  
  status          TPAStatus @default(VERIFICATION_PENDING)
  
  preAuthNo       String?
  preAuthDate     DateTime?
  preAuthAmount   Decimal?  @db.Decimal(12, 2)
  
  claimNo         String?
  claimDate       DateTime?
  claimAmount     Decimal?  @db.Decimal(12, 2)
  
  settledAmount   Decimal?  @db.Decimal(12, 2)
  settledDate     DateTime?
  tdsDeducted     Decimal?  @db.Decimal(10, 2)
  
  rejectionReason String?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([invoiceId])
  @@index([patientId])
  @@map("tpa_claims")
}

// ============================================================
// ACCOUNTING (Double-Entry)
// ============================================================

model Account {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  
  accountCode     String      // e.g. "1100", "4000", "2100"
  accountName     String      // e.g. "Accounts Receivable", "Consultation Revenue"
  accountType     AccountType
  parentAccountId String?
  
  balance         Decimal     @default(0) @db.Decimal(15, 2)
  isSystem        Boolean     @default(false)  // System accounts can't be deleted
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  journalLines    JournalLine[]

  @@unique([tenantId, accountCode])
  @@index([tenantId])
  @@map("accounts")
}

model JournalEntry {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  invoiceId       String?
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  
  entryType       JournalEntryType
  entryDate       DateTime         @default(now())
  referenceNo     String?
  description     String
  
  totalDebit      Decimal          @db.Decimal(15, 2)
  totalCredit     Decimal          @db.Decimal(15, 2)
  
  isPosted        Boolean          @default(true)
  postedBy        String?          // User ID
  
  createdAt       DateTime         @default(now())

  lines           JournalLine[]

  @@index([tenantId, entryDate])
  @@index([invoiceId])
  @@map("journal_entries")
}

model JournalLine {
  id              String       @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])
  
  debitAmount     Decimal      @default(0) @db.Decimal(15, 2)
  creditAmount    Decimal      @default(0) @db.Decimal(15, 2)
  narration       String?

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ============================================================
// GST CONFIGURATION
// ============================================================

model GSTRate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  sacHsnCode  String
  description String
  cgstRate    Decimal  @db.Decimal(5, 2)
  sgstRate    Decimal  @db.Decimal(5, 2)
  igstRate    Decimal  @db.Decimal(5, 2)
  isExempt    Boolean  @default(false)
  
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([tenantId, sacHsnCode])
  @@map("gst_rates")
}

// ============================================================
// NOTIFICATIONS & ALERTS
// ============================================================

model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  userId      String?   // Null = broadcast to role
  targetRole  String?   // Role to broadcast to
  
  type        AlertType
  title       String
  message     String
  referenceId String?   // ID of related entity
  referenceType String? // "INVOICE", "INVENTORY", "APPOINTMENT"
  
  isRead      Boolean   @default(false)
  readAt      DateTime?
  
  createdAt   DateTime  @default(now())

  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

// ============================================================
// AUDIT LOG (Append-only)
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  
  action      AuditAction
  tableName   String
  recordId    String
  
  oldData     Json?       // Before state (JSONB)
  newData     Json?       // After state (JSONB)
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime    @default(now())

  @@index([tenantId, tableName, recordId])
  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}
